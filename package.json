{
  "name": "zettamine-corp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Zettamine — corporate website (standalone Nuxt 4 + Vue 3 + Tailwind v4)",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "generate:pages": "cross-env NUXT_GITHUB_PAGES=true nuxt generate",
    "preview": "nuxt preview",
    "start": "cross-env NITRO_HOST=127.0.0.1 NITRO_PORT=5003 node .output/server/index.mjs",
    "postinstall": "nuxt prepare"
