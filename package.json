  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.105",
    "@nuxt/icon": "^2.2.1",
    "@nuxtjs/color-mode": "^4.0.0",
    "@tailwindcss/vite": "^4.1.4",
    "@vueuse/core": "^13.0.0",
    "@vueuse/nuxt": "^13.0.0",
    "cross-env": "^7.0.3",
    "tailwindcss": "^4.1.4"
  }
}
